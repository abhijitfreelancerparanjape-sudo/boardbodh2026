# Supabase (project under abhijitfreelancerparanjape@gmail.com)
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BoardBodh

# Claude API (Phase 1 — studio question generation, server-side only)
ANTHROPIC_API_KEY=
# Model for generation. Defaults to claude-opus-4-8 (most capable). Set to
# claude-sonnet-4-6 to cut generation cost ~40% input / ~60% output.
ANTHROPIC_MODEL=claude-opus-4-8
# Approx USD->INR rate used only to present generation cost in INR for review.
USD_TO_INR=88

# Studio access: comma-separated admin emails allowed into /studio.
ADMIN_EMAILS=
